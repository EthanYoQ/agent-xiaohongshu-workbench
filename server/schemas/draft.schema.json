{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "body", "tags", "imageCards", "editorNote"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 20 },
    "body": { "type": "string" },
    "editorNote": { "type": "string" },
    "tags": { "type": "array", "minItems": 3, "maxItems": 10, "items": { "type": "string" } },
    "imageCards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kicker", "headline", "body", "characterAction"],
        "properties": {
          "kicker": { "type": "string", "description": "Reader-facing label only; never include internal brand, layout, motif, prompt, or production terminology." },
          "headline": { "type": "string", "description": "Reader-facing headline only; never expose analysis or visual-direction terminology." },
          "body": { "type": "string", "description": "Reader-facing card copy only; never include canvas dimensions, colors, layout instructions, prompts, or production notes." },
          "characterAction": { "type": "string" }
        }
      }
    }
  }
}
