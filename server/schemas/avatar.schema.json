{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "prompt", "assetPath", "identityLock", "blocker"],
  "properties": {
    "status": { "type": "string", "enum": ["success", "blocked"] },
    "prompt": { "type": "string" },
    "assetPath": { "type": "string" },
    "identityLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["character", "faceAndHair", "outfit", "renderingStyle", "invariants"],
      "properties": {
        "character": { "type": "string" },
        "faceAndHair": { "type": "string" },
        "outfit": { "type": "string" },
        "renderingStyle": { "type": "string" },
        "invariants": { "type": "array", "minItems": 3, "items": { "type": "string" } }
      }
    },
    "blocker": { "type": "string" }
  }
}
