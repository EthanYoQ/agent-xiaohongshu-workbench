{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["characterAssets", "editorNote"],
  "properties": {
    "editorNote": { "type": "string" },
    "characterAssets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "filePath"],
        "properties": {
          "action": { "type": "string" },
          "filePath": { "type": "string" }
        }
      }
    }
  }
}
