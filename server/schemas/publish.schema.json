{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "noteId", "url", "message", "evidence"],
  "properties": {
    "status": { "type": "string", "enum": ["published", "draft_saved", "unknown", "failed"] },
    "noteId": { "type": ["string", "null"] },
    "url": { "type": ["string", "null"] },
    "message": { "type": "string" },
    "evidence": { "type": "string" }
  }
}
